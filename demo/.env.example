# Default OpenAI-compatible provider used by Pages Functions.
OPENAI_API_URL="https://api.deepseek.com"
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="deepseek-v4-flash"

# Optional GitHub token. Strongly recommended to avoid low anonymous rate limits.
GITHUB_TOKEN="github_pat_..."

# Optional Supabase cache. If omitted, SIU still works without cross-user cache.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="..."

# Increment when prompt behavior changes and old analysis cache should not be reused.
PROMPT_VERSION="prompt_v5"

# Local debugging only. Logs full AI prompt and raw model response.
DEBUG_AI_CONTEXT="false"
